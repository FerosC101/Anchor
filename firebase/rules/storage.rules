rules_version = '2';
service firebase.storage {
	match /b/{bucket}/o {
		function _role() {
			return get(/databases/(default)/documents/users/$(request.auth.uid)).data.role;
		}

		function _isGovernmentOrNgo() {
			return request.auth != null && (_role() == 'government' || _role() == 'ngo');
		}

		function _isAdmin() {
			return request.auth != null && _role() == 'admin';
		}

		function _isAllowedContentType() {
			return request.resource.contentType.matches('application/pdf') ||
				request.resource.contentType.matches('image/jpeg') ||
				request.resource.contentType.matches('image/png') ||
				request.resource.contentType.matches('text/plain');
		}

		// contracts/{userId}/{contractId}-{fileName}
		match /contracts/{userId}/{fileName} {
			allow read: if request.auth != null &&
				(request.auth.uid == userId || _isGovernmentOrNgo() || _isAdmin());

			allow write: if request.auth != null &&
				request.auth.uid == userId &&
				request.resource.size < 10 * 1024 * 1024 &&
				_isAllowedContentType();
		}

		// Deny everything else by default.
		match /{allPaths=**} {
			allow read, write: if false;
		}
	}
}
